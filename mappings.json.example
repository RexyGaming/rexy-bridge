{
  "_README": [
    "This file maps OSC paths to UE5 Remote Control writes.",
    "",
    "Replace these placeholders with the actual values from YOUR UE5 project:",
    "  <YOUR_PROJECT>  — the Game folder name, e.g. 'VprodProject'",
    "  <YOUR_LEVEL>    — the level / map name, e.g. 'Main'",
    "  <YOUR_CAMERA>   — the CineCameraActor name, e.g. 'CineCameraActor_1'",
    "  <YOUR_CRANE>    — the CameraRig_Crane name, e.g. 'CameraRig_Crane_1'",
    "",
    "How to find these: see docs/ue5-setup.md → 'Finding your paths'.",
    "Or run the bridge with --verbose and watch what gets logged when you select a camera in the app.",
    "",
    "After editing, save as 'mappings.json' (the .example version isn't read by the bridge)."
  ],

  "ue5": {
    "host": "127.0.0.1",
    "ws_port": 30020,
    "access": "WRITE_ACCESS",
    "suppress_udp_when_handled": false,
    "reconnect_seconds": 3.0,
    "crane_rerun_construction": false
  },

  "mappings": [
    {
      "osc": "/rexy/pan",
      "label": "Camera Pan",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CAMERA>.SceneComponent",
      "propertyName": "RelativeRotation",
      "component": "Yaw",
      "struct_init": { "Pitch": 0.0, "Yaw": 0.0, "Roll": 0.0 },
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": -180.0,
      "out_max": 180.0,
      "bipolar": true,
      "curve": 1.0,
      "invert": false
    },
    {
      "osc": "/rexy/tilt",
      "label": "Camera Tilt",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CAMERA>.SceneComponent",
      "propertyName": "RelativeRotation",
      "component": "Pitch",
      "struct_init": { "Pitch": 0.0, "Yaw": 0.0, "Roll": 0.0 },
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": -90.0,
      "out_max": 90.0,
      "bipolar": true,
      "curve": 1.0,
      "invert": true
    },
    {
      "osc": "/rexy/roll",
      "label": "Camera Roll",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CAMERA>.SceneComponent",
      "propertyName": "RelativeRotation",
      "component": "Roll",
      "struct_init": { "Pitch": 0.0, "Yaw": 0.0, "Roll": 0.0 },
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": -45.0,
      "out_max": 45.0,
      "bipolar": true,
      "curve": 1.0,
      "invert": false
    },
    {
      "osc": "/rexy/zoom",
      "label": "Zoom (Focal Length)",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CAMERA>.CameraComponent",
      "propertyName": "CurrentFocalLength",
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": 24.0,
      "out_max": 120.0,
      "invert": false
    },
    {
      "osc": "/rexy/aperture",
      "label": "Aperture (f-stop)",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CAMERA>.CameraComponent",
      "propertyName": "CurrentAperture",
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": 1.4,
      "out_max": 16.0,
      "invert": false
    },
    {
      "osc": "/rexy/focus",
      "label": "Focus Distance",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CAMERA>.CameraComponent",
      "propertyName": "FocusSettings",
      "component": "ManualFocusDistance",
      "struct_init": {},
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": 30.0,
      "out_max": 100000.0,
      "scale_type": "log",
      "invert": false
    },
    {
      "osc": "/rexy/craneYaw",
      "label": "Crane Yaw",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CRANE>",
      "propertyName": "CraneYaw",
      "access": "WRITE_TRANSACTION_ACCESS",
      "write_throttle_ms": 100,
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": -180.0,
      "out_max": 180.0,
      "bipolar": true,
      "curve": 1.0,
      "invert": false
    },
    {
      "osc": "/rexy/cranePitch",
      "label": "Crane Pitch",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CRANE>",
      "propertyName": "CranePitch",
      "access": "WRITE_TRANSACTION_ACCESS",
      "write_throttle_ms": 100,
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": -45.0,
      "out_max": 45.0,
      "bipolar": true,
      "curve": 1.0,
      "invert": false
    },
    {
      "osc": "/rexy/scope",
      "label": "Scope (Crane Arm Length)",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CRANE>",
      "propertyName": "CraneArmLength",
      "access": "WRITE_TRANSACTION_ACCESS",
      "write_throttle_ms": 100,
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": 100.0,
      "out_max": 1000.0,
      "invert": false
    },
    {
      "osc": "/rexy/baseX",
      "label": "Crane Base X",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CRANE>.TransformComponent",
      "propertyName": "RelativeLocation",
      "component": "X",
      "struct_init": { "X": 0.0, "Y": 0.0, "Z": 0.0 },
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": -1200.0,
      "out_max": -200.0,
      "bipolar": true,
      "curve": 1.0,
      "invert": false
    },
    {
      "osc": "/rexy/baseY",
      "label": "Crane Base Y",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CRANE>.TransformComponent",
      "propertyName": "RelativeLocation",
      "component": "Y",
      "struct_init": { "X": 0.0, "Y": 0.0, "Z": 0.0 },
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": -730.0,
      "out_max": 270.0,
      "bipolar": true,
      "curve": 1.0,
      "invert": false
    },
    {
      "osc": "/rexy/baseZ",
      "label": "Crane Base Z",
      "objectPath": "/Game/<YOUR_PROJECT>/Maps/<YOUR_LEVEL>.<YOUR_LEVEL>:PersistentLevel.<YOUR_CRANE>.TransformComponent",
      "propertyName": "RelativeLocation",
      "component": "Z",
      "struct_init": { "X": 0.0, "Y": 0.0, "Z": 0.0 },
      "in_min": 0.0,
      "in_max": 1.0,
      "out_min": 0.0,
      "out_max": 1000.0,
      "invert": false
    }
  ]
}
